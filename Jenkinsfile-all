pipeline {
    agent none

    parameters {
        string(name: 'Srikar', defaultValue: 'Srikar', description: 'Enter the name')
    }

    environment {
        APP_NAME = "DEVOPS"
    }

    stages {
        stage('Print App Name') {
            agent any
            steps {
                echo "Application name: ${APP_NAME}"
            }
        }
    }
}